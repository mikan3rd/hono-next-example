{
  "name": "e2e",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck": "bun run --bun tsgo --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check . --write --unsafe",
    "check:all": "bun install && bun run lint:fix && bun run typecheck",
    "e2e:local": "dotenvx run -- bun playwright test",
    "e2e:local:ui": "dotenvx run -- bun playwright test --ui",
    "e2e:docker": "bun playwright test",
    "e2e:docker:screenshot": "bun playwright test --update-snapshots",
    "e2e:show-report": "bun playwright show-report"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@dotenvx/dotenvx": "1.61.6",
    "@playwright/test": "1.59.1",
    "@t3-oss/env-core": "0.13.11",
    "@types/node": "24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260424.2",
    "zod": "4.3.6"
  }
}
