{
  "root": false,
  "extends": "//",
  "overrides": [
    {
      "includes": ["src/client/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "useTemplate": "off"
          },
          "suspicious": {
            "noConfusingVoidType": "off"
          }
        }
      }
    }
  ]
}
